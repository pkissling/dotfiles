Include ~/.orbstack/ssh/config
Include ~/.ssh/config_profile_specific

Host *
  UseKeychain yes
  AddKeysToAgent yes
  IdentityFile ~/.ssh/id_rsa
  SetEnv TERM=xterm-256color

Host diskstation
  User patrick

Host home-server
  User patrick

Host patricks-mac-mini
  User patrick

Host patricks-mac-mini
  User patrick

Host coding
  User patrick

Host github.com
    HostName github.com
    Port 22
    User git
    IdentityFile ~/.ssh/private.priv
