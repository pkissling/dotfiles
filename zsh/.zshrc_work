alias cds="cd ${HYBRIS_HOME_DIR}/miscellaneous/scripts"
alias cdp="cd ${HYBRIS_HOME_DIR}/hybris/bin/platform"
alias buildNoFrontend="cdp && . ./setantenv.sh && ant build -DbuildFrontend=false -Dbackoffice.sass.enabled=false"
alias buildOnlyFrontend="cdp && . ./setantenv.sh && ant build_js_in_dev_mode_for_acctests"
alias rebuildAll="cdp && . ./setantenv.sh && ant clean customize && ant updateMavenDependencies && ant all"
